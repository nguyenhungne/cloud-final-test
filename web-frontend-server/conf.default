server {
    listen 80;
    server_name localhost;

    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /blog/ {
        try_files $uri $uri/ =404;
    }

    # Nginx status for Prometheus exporter
    location /nginx_status {
        stub_status on;
        access_log off;
        allow all;
    }

    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;
}
